@model List<ClickCollect_Antoine_Nolan_2026.Models.ProductQuantity>

@{
    ViewData["Title"] = "Your Shopping cart";
}

<div class="container py-5">
    <h2 class="mb-4">Here's your shopping cart, @ViewData["Username"] !</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">
            Your cart is empty ! <a asp-controller="Home" asp-action="Index">Back to the catalog</a>
        </div>
    }
    else
    {
        <form method="post" asp-controller="Cart" asp-action="UpdateCart">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                
                    @for (int i = 0 ; i < Model.Count ; i++)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@Model[i].Product.ImageLink" alt="@Model[i].Product.Name" style="width: 60px; height: 60px; object-fit: contain;"/>
                                    <a asp-controller="Product" asp-action="ViewProduct" 
                                    asp-route-id="@Model[i].Product.ProductId">
                                        @Model[i].Product.Name
                                    </a>
                                </div>
                            </td>
                            <td>@Model[i].Product.Price.ToString("F2") €</td>
                            <td>
                                <input type="number" asp-for="@Model[i].Quantity" value="@Model[i].Quantity" min="1" max="500"
                                       class="form-control" style="width: 80px;" />
                            </td>
                            <td>@((Model[i].Product.Price * Model[i].Quantity).ToString("F2")) €</td>
                            <td>
                                <input class="d-none" type="submit" name="action" value="save" />
                                <button type="submit" name="action" class="btn btn-sm btn-outline-danger" value="@Model[i].Product.ProductId">
                                    Remove the product
                                </button>
                                <input type="hidden" asp-for="@Model[i].Product.ProductId" />
                                <input type="hidden" asp-for="@Model[i].Product.Price" />
                                <input type="hidden" asp-for="@Model[i].Product.Name" />
                                <input type="hidden" asp-for="@Model[i].Product.ImageLink" />
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">For each command you have a service fee of :</td>
                        <td class="fw-bold text-primary">@Order.TaxOfService €</td>
                        <td></td>
                    </tr>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Your total is :</td>
                        <td class="fw-bold text-primary">
                            @((Model.Sum(p => p.Product.Price * p.Quantity) + @Order.TaxOfService).ToString("F2")) €
                        </td>
                        <td>
                            <button type="submit" name="action" class="btn btn-primary" value="save">
                                Save cart changes
                            </button>
                        </td>
                    </tr>
                </tfoot>
            </table>

            <div class="d-flex justify-content-between mt-4">

                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark"> Continue to shop</a>
                <button type="submit" name="action" class="btn btn-primary" value="confirm">
                    Process to take order
                </button>
            </div>
        </form>
    }
</div>
