@{
    ViewData["Title"] = "Cashier Area";
}

<div class="container mt-5">
    <partial name="_ErrorSuccessMessagesPartial" />
    <div class="card border-primary mb-3">
        <div class="card-header bg-primary text-white fw-bold">🛒 Cashier Area</div>
        <div class="card-body">
            <h5 class="card-title">Hello, @ViewData["Username"] !</h5>
            <p class="card-text">Welcome to your checkout station. This is where you'll be able to look up customer orders to confirm their pickup.</p>
            <hr />
            <div class="alert alert-info">
                <strong>Status :</strong> Secure access for the Cashier role is now fully operational.
            </div>
        </div>
    </div>
</div>
