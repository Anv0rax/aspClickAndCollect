@model Order
@{
}
<partial name="_CartContentPartial" model="@Model.Content"></partial>

<form method="post" asp-controller="Cashier" asp-action="Confirm" asp-route-id="@Model.OrderId">
    <div class="mb-4">
        <label class="form-label fw-bold">Number of boxes returned :</label>
        <input type="number" name="boxesReturned" min="0" value="0" class="form-control col-lg-2"
               style="width: 80px;" onchange="changePriceForBoxes(this, ' @Order.BoxDeposit ' ) " />
        <small class="text-muted">Each box costs @Order.BoxDeposit € as a deposit.</small>
    </div>

    <div class="d-flex justify-content-between mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to order list</a>
        <input type="hidden" class="d-none" name="boxesUsed" value="@Model.NumberOfBoxUsed" />
        <button type="submit" class="btn btn-success fw-bold">
            Confirm
        </button>
    </div>
</form>