@model List<Product>

@{
    ViewData["Title"] = "Shop - Catalog";
    string sort = ViewData["Sort"] as string ?? "";
    string selectedCategory = ViewData["Category"] as string ?? "";
    string search = ViewData["Search"] as string ?? "";
    List<Product> allProducts = ViewData["AllProducts"] as List<Product> ?? new List<Product>();
}

<div class="container py-5">
    <partial name="_ErrorSuccessMessagesPartial" />
    <div class="row">
        <aside class="col-lg-3 mb-4">
            <div class="card shadow-sm border-0 mb-4">
                <form method="get" asp-action="Index" class="card-body">
                    <h5 class="mb-3">Search</h5>
                    <div class="input-group">
                        <input type="text" name="search" class="form-control border-light" placeholder="Apple, pasta..." aria-label="Search" value="@search" />
                        @if(!string.IsNullOrEmpty(selectedCategory))
                        {
                            <input type="hidden" name="category" value="@selectedCategory" />
                        }
                        @if (!string.IsNullOrEmpty(sort))
                        {
                            <input type="hidden" name="sort" value="@sort" />
                        }
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"> 🔎 </i>
                        </button>
                    </div>
                </form>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="mb-3">Categories</h5>
                    <div class="list-group list-group-flush">
                        <a asp-route-search="@search" asp-route-category=" " asp-route-sort=" @sort"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-2 @(selectedCategory == "" ? "active" : "")">
                            All the products 
                            <span class="badge @(selectedCategory == "" ? "bg-primary" : "bg-secondary") rounded-pill">
                                @allProducts?.Count
                            </span>
                        </a>
                        @foreach (var cat in allProducts?.SelectMany(p => p.CategoryProduct).GroupBy(c => c.Id).Select(g => g.First()) ?? Enumerable.Empty<ClickCollect_Antoine_Nolan_2026.Models.Category>())
                        {
                            <a asp-route-search="@search" asp-route-category="@cat.NameCategory" asp-route-sort="@sort"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0 @(selectedCategory == cat.NameCategory ? "active" : "")">
                                @cat.NameCategory
                                <span class="badge @(selectedCategory == cat.NameCategory ? "bg-white text-primary" : "bg-secondary") rounded-pill">
                                    @allProducts?.Count(p => p.CategoryProduct.Any(c => c.Id == cat.Id))
                                </span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </aside>

        <main class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="h4 mb-0">Our catalog</h2>
                <select class="form-select w-auto border-0 shadow-sm" onchange="sendSortProduct(this, '@selectedCategory', '@search')">
                    <option value="" selected="@(sort == null)">Sort by :</option>
                    <option value="name" selected="@(sort == "name")">Name</option>
                    <option value="ascending" selected="@(sort == "ascending")">Price : Ascending ⬆️</option>
                    <option value="descending" selected="@(sort == "descending")">Price : Descending ⬇️</option>
                </select>
            </div>

            @if (Model == null || Model.Count == 0)
            {
                <div class="alert alert-warning">No products were found in the catalog.</div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 product-card">
                                <div class="p-3 text-center">
                                    <img src="@item.ImageLink" class="card-img-top rounded" alt="@item.Name" style="height: 180px; object-fit: contain;">
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-subtitle mb-2 text-muted small">
                                        @string.Join(", ", item.CategoryProduct.Select(c => c.NameCategory))
                                    </h6>
                                    <h5 class="card-title h6">@item.Name</h5>
                                    <div class="mt-auto">
                                        @if (ViewData["Role"]?.ToString() != "Preparer" && ViewData["Role"]?.ToString() != "Cashier")
                                        {
                                            <div class="mb-2">
                                                <a asp-controller="Product" asp-action="ViewProduct" asp-route-id="@item.ProductId"
                                                   class="btn btn-sm btn-light w-100 border-0 shadow-sm" style="font-size: 0.8rem;">
                                                    <i class="bi bi-info-circle me-1"></i> More Details
                                                </a>
                                            </div>
                                        }
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="h5 mb-0 text-primary">@item.Price.ToString("F2")€</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </main>
    </div>
</div>
