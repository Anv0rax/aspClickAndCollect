@model ClickCollect_Antoine_Nolan_2026.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-5">
    <div class="card border-primary shadow-sm">
        <div class="card-header bg-primary text-white fw-bold">
            Order #@Model.OrderId — Details
        </div>
        <div class="card-body">

            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="fw-bold">Customer</h6>
                    <p>@Model.Client.Username</p>
                </div>
                <div class="col-md-6">
                    <h6 class="fw-bold">Pickup Time</h6>
                    <p>@Model.Slot?.StartTime.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <h6 class="fw-bold mb-3">Products to prepare</h6>

            @if (Model.Content == null || Model.Content.Count == 0)
            {
                <div class="alert alert-warning">No products found for this order.</div>
            }
            else
            {
                <table class="table table-hover align-middle border">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Content)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@item.Product.ImageLink" alt="@item.Product.Name"
                                             style="width: 50px; height: 50px; object-fit: contain;" />
                                        <span>@item.Product.Name</span>
                                    </div>
                                </td>
                                <td>@item.Product.Price.ToString("F2") €</td>
                                <td>@item.Quantity</td>
                                <td>@((item.Product.Price * item.Quantity).ToString("F2")) €</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Total :</td>
                            <td class="fw-bold text-primary">
                                @((Model.Content.Sum(p => p.Product.Price * p.Quantity)).ToString("F2")) €
                            </td>
                        </tr>
                    </tfoot>
                </table>
            }

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary">Back to orders</a>
                <a asp-action="Prepare" asp-route-id="@Model.OrderId" class="btn btn-success">
                    Start Preparing
                </a>
            </div>
        </div>
    </div>
</div>
