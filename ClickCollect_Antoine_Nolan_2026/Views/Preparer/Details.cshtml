@model ClickCollect_Antoine_Nolan_2026.Models.Order
@{
    ViewData["Title"] = "Order Details & Preparation";
}

<div class="container mt-5">
    <div class="card border-primary shadow-sm">
        <div class="card-header bg-primary text-white fw-bold">
            Order #@Model.OrderId — Details & Preparation
        </div>
        <div class="card-body">

            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="fw-bold">Pickup Time</h6>
                    <p>@Model.Slot?.StartTime.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <h6 class="fw-bold mb-3">Products to prepare</h6>
            @if (Model.Content == null || Model.Content.Count == 0)
            {
                <div class="alert alert-warning">No products found for this order.</div>
            }
            else
            {
                <table class="table table-hover align-middle border">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Content)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@item.Product.ImageLink" alt="@item.Product.Name"
                                             style="width: 50px; height: 50px; object-fit: contain;" />
                                        <span>@item.Product.Name</span>
                                    </div>
                                </td>
                                <td>@item.Quantity</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <form method="post" asp-controller="Preparer" asp-action="Prepare" asp-route-id="@Model.OrderId">
                <hr class="my-4" />
                <h6 class="fw-bold mb-3">Preparation</h6>
                <div class="mb-3">
                    <label class="form-label fw-bold">Number of boxes used :</label>
                    <input type="number" name="numberOfBoxUsed" min="1" value="1"
                           class="form-control" style="width: 150px;" />
                    <small class="text-muted">Each box costs @Order.BoxDeposit.ToString("F2") € as a deposit.</small>
                </div>
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to orders</a>
                    <button type="submit" class="btn btn-success fw-bold">
                        Mark as Ready
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>
