@model ClickCollect_Antoine_Nolan_2026.Models.Order

@{
    ViewData["Title"] = "Prepare Order";
}

<div class="container mt-5">
    <div class="card border-success shadow-sm">
        <div class="card-header bg-success text-white fw-bold">
            Prepare Order #@Model.OrderId
        </div>
        <div class="card-body">

            <partial name="_ErrorSuccessMessagesPartial" />

            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="fw-bold">Customer</h6>
                    <p>@Model.Client.Username</p>
                </div>
                <div class="col-md-6">
                    <h6 class="fw-bold">Pickup Time</h6>
                    <p>@Model.Slot?.StartTime.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <form method="post" asp-controller="Preparer" asp-action="Prepare" asp-route-id="@Model.OrderId">
                <div class="mb-4">
                    <label class="form-label fw-bold">Number of boxes used :</label>
                    <input type="number" name="numberOfBoxUsed" min="1" value="1"
                           class="form-control" style="width: 150px;" />
                    <small class="text-muted">Each box costs @Order.BoxDeposit € as a deposit.</small>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Details" asp-route-id="@Model.OrderId"
                       class="btn btn-outline-secondary">Back to details</a>
                    <button type="submit" class="btn btn-success fw-bold">
                        Mark as Ready
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
