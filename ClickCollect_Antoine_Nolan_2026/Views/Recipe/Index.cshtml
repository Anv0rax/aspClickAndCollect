@model List<Recipe>
@{
    ViewData["Title"] = "Our Recipes";
}

<div class="container py-5">

    <partial name="_ErrorSuccessMessagesPartial" />

    <h2 class="fw-bold mb-4">Our Recipes</h2>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-warning">No recipes available at the moment.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var recipe in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <p class="card-text text-muted">@recipe.Description</p>
                            <p class="text-muted small">
                                @recipe.Ingredients.Count ingredient(s)
                            </p>
                            <div class="mt-auto">
                                <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.RecipeId"
                                   class="btn btn-outline-primary w-100">
                                    See ingredients
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>