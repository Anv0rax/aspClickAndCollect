<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="512x512" href="~/favicon.png">
    <title>@ViewData["Title"] - ClickCollect</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClickCollect_Antoine_Nolan_2026.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="p-3 text-bg-light">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
                <a href="/" class="d-flex align-items-center mb-2 mb-lg-0 text-dark text-decoration-none">
                    <svg class="navbar-toggler-icon me-2" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <rect width="44" height="44" rx="9" fill="#378ADD"></rect>
                        <path d="M0 31 H44 V36 Q44 44 35 44 H9 Q0 44 0 36 Z" fill="#F26D3B"></path>
                        <circle cx="22" cy="17" r="9" fill="white"></circle>
                        <circle cx="22" cy="17" r="4" fill="#378ADD"></circle>
                        <line x1="22" y1="26" x2="22" y2="31" stroke="white" stroke-width="2.5" stroke-linecap="round"></line>
                    </svg>
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Click & Collect</a>
                </a>
                <ul class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0">
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link px-2 text-secondary">
                            Home
                        </a>
                    </li>
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link px-2 text-dark">
                            Features
                        </a>
                    </li>
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link px-2 text-dark">
                            Pricing
                        </a>
                    </li>
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link px-2 text-dark">
                            FAQs
                        </a>
                    </li>
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="nav-link px-2 text-dark">
                            About
                        </a>
                    </li>
                </ul>
                @if ((bool?)ViewData["IsLoggedIn"] == true)
                {
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-primary me-2">
                        <i class="bi bi-cart">Cart</i>
                    </a>
                    <a asp-controller="User" asp-action="Logout" class="btn btn-outline-dark me-2">
                        Logout
                    </a>
                }
                else
                {
                   <a asp-controller="User" asp-action="Login" class="btn btn-outline-dark me-2">
                       Login
                   </a>
                    <a asp-controller="User" asp-action="Register" class="btn btn-warning">
                        Sign-up
                    </a>
                }
            </div>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer modal-footer text-muted">
        <div class="container">
            &copy; 2026 - ClickCollect_Antoine_Nolan_2026 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
