@model ClickCollect_Antoine_Nolan_2026.Models.Customer

@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <h2 class="mb-4">Create an account</h2>

        <partial name="_ErrorSuccessMessagesPartial" />

        <form method="post" asp-controller="User" asp-action="Register">

            <h5 class="mt-3 mb-2">Account information</h5>

            <div class="mb-3">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <h5 class="mt-4 mb-2">Address</h5>

            <div class="mb-3">
                <label asp-for="Adress.Street" class="form-label"></label>
                <input asp-for="Adress.Street" class="form-control" />
                <span asp-validation-for="Adress.Street" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Adress.Number" class="form-label"></label>
                <input asp-for="Adress.Number" class="form-control" />
                <span asp-validation-for="Adress.Number" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Adress.City" class="form-label"></label>
                <input asp-for="Adress.City" class="form-control" />
                <span asp-validation-for="Adress.City" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Adress.Country" class="form-label"></label>
                <input asp-for="Adress.Country" value="Belgium" class="form-control" />
                <span asp-validation-for="Adress.Country" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-2">Create account</button>
        </form>

        <p class="mt-3 text-center">
            Already have an account ? <a asp-controller="User" asp-action="Login">Log in</a>
        </p>

        @section Scripts {
            @await Html.PartialAsync("_ValidationScriptsPartial")
        }
    </div>
</div>
