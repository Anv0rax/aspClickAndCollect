@model ClickCollect_Antoine_Nolan_2026.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <h2 class="mb-4">Create an account</h2>

        @if (ViewData["Error"] != null)
        {
            <div class="alert alert-danger">@ViewData["Error"]</div>
        }

        <form method="post" asp-controller="User" asp-action="Register">

            <h5 class="mt-3 mb-2">Account information</h5>

            <div class="mb-3">
                <label asp-for="Customer.FirstName" class="form-label"></label>
                <input asp-for="Customer.FirstName" class="form-control" />
                <span asp-validation-for="Customer.FirstName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Customer.LastName" class="form-label"></label>
                <input asp-for="Customer.LastName" class="form-control" />
                <span asp-validation-for="Customer.LastName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Customer.Username" class="form-label"></label>
                <input asp-for="Customer.Username" class="form-control" />
                <span asp-validation-for="Customer.Username" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Customer.Password" class="form-label"></label>
                <input asp-for="Customer.Password" type="password" class="form-control" />
                <span asp-validation-for="Customer.Password" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Customer.Email" class="form-label"></label>
                <input asp-for="Customer.Email" class="form-control" />
                <span asp-validation-for="Customer.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Customer.PhoneNumber" class="form-label"></label>
                <input asp-for="Customer.PhoneNumber" class="form-control" />
                <span asp-validation-for="Customer.PhoneNumber" class="text-danger"></span>
            </div>

            <h5 class="mt-4 mb-2">Address</h5>

            <div class="col-md-9 mb-3">
                <label asp-for="Customer.AdressCustomer.Street" class="form-label"></label>
                <input asp-for="Customer.AdressCustomer.Street" class="form-control" />
                <span asp-validation-for="Customer.AdressCustomer.Street" class="text-danger"></span>
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="Customer.AdressCustomer.Number" class="form-label"></label>
                <input asp-for="Customer.AdressCustomer.Number" class="form-control" />
                <span asp-validation-for="Customer.AdressCustomer.Number" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Customer.AdressCustomer.City" class="form-label"></label>
                <input asp-for="Customer.AdressCustomer.City" class="form-control" />
                <span asp-validation-for="Customer.AdressCustomer.City" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Customer.AdressCustomer.Country" class="form-label"></label>
                <input asp-for="Customer.AdressCustomer.Country" class="form-control" />
                <span asp-validation-for="Customer.AdressCustomer.Country" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-2">Create account</button>
        </form>

        <p class="mt-3 text-center">
            Already have an account ? <a asp-controller="User" asp-action="Login">Log in</a>
        </p>

        @section Scripts {
            @await Html.PartialAsync("_ValidationScriptsPartial")
        }
    </div>
</div>
